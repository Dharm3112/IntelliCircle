{
  "name": "intellicircle-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:client": "npm run dev -w @intellicircle/client",
    "dev:server": "npm run dev -w @intellicircle/server",
    "build:client": "npm run build -w @intellicircle/client",
    "build:server": "npm run build -w @intellicircle/server",
    "check": "tsc --noEmit"
  }
}