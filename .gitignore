# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
packages/*/node_modules

# testing
/coverage

# next.js
/.next/
/out/
packages/client/.next/

# production
/build
/dist
packages/*/dist

# misc
.DS_Store
*.pem

# logs
*.log

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# local env files — never commit real secrets
.env
.env.local
.env*.local
.env.development
.env.production
.env.keys

# debug / scratch output files
inject_*.txt
tree.txt

# ad-hoc test scripts (proper tests live in __tests__/)
test_*.js
test_*.ts

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Replit
.replit
replit.md

# Required Documents (private project docs)
Tech Stack.md
Problem Statement.md
Design Doc.md
PRD.md
TODO.md