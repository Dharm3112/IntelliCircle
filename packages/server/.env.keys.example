# RSA key pair for JWT RS256 authentication
# Generate with: node generate-keys.js (from the project root)
#
# Paste the full PEM-encoded keys below (keep the \n escape sequences on a single line).

JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----\n"
