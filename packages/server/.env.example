# Server configuration
PORT=8080
NODE_ENV=development

# PostgreSQL connection string (must have PostGIS extension enabled)
DATABASE_URL="postgresql://user:password@localhost:5432/intellicircle"

# Redis connection string (local or Upstash serverless)
REDIS_URL="redis://localhost:6379"

# A simple secret for development — not used in production (RS256 keys are used instead)
JWT_SECRET="change-me-to-a-random-string"

# Google Gemini API key for AI chat summaries (optional)
GEMINI_API_KEY=""

# OpenCage API key for reverse geocoding (optional)
OPENCAGE_API_KEY=""
